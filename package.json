{
  "name": "jsonl-editor",
  "displayName": "JSONL Edit/Preview",
  "description": "Edit individual JSON lines in JSONL files",
  "publisher": "toiroakr",
  "version": "0.5.1",
  "icon": "assets/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "JSON",
    "JSONL",
    "JSON Lines"
  ],
  "engines": {
    "vscode": "^1.99.0"
  },
  "license": "MIT",
  "activationEvents": [
    "onLanguage:jsonl"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonl-editor.editJsonlLine",
        "title": "Edit JSONL line"
      },
      {
        "command": "jsonl-editor.previewJsonl",
        "title": "Preview JSONL"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "jsonl-editor.editJsonlLine",
          "when": "resourceExtname == .jsonl",
          "group": "navigation"
        },
        {
          "command": "jsonl-editor.previewJsonl",
          "when": "resourceExtname == .jsonl",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "JSONL Editor",
      "properties": {
        "jsonl-editor.disableEditLink": {
          "type": "boolean",
          "default": false,
          "description": "Disable the Cmd/Ctrl+Click document link on JSON lines. Enable this if you find the underline VS Code renders under each JSON line distracting; you can still edit lines via Code Lens, Quick Fix, or the command palette."
        }
      }
    }
  },
  "scripts": {
    "vscode:publish": "pnpm dlx vsce publish --no-dependencies",
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "preview-dev": "node src/preview-dev-server.js"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.39",
    "@types/vscode": "1.116.0",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "npm-run-all": "4.1.5",
    "typescript": "5.9.3",
    "undici-types": "7.25.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/toiroakr/jsonl-editor"
  }
}
